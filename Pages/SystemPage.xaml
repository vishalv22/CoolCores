<Page
    x:Class="CoolCores.Pages.SystemPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Resources>
        <Style x:Key="SystemCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF1F1F1F" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="MinHeight" Value="120" />
        </Style>
    </Page.Resources>

    <ScrollViewer>
        <Grid Padding="20"
              RowSpacing="12"
              ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource SystemCardStyle}" Grid.Row="0" Grid.Column="0">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE950;" />
                        <TextBlock Text="Processor"
                                   FontSize="16"
                                   FontWeight="Normal" />
                    </StackPanel>
                    <TextBlock x:Name="ProcessorNameTextBlock"
                               Text="Loading..."
                               TextWrapping="WrapWholeWords"
                               Foreground="#FFD1D1D1" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SystemCardStyle}" Grid.Row="0" Grid.Column="1"><TextBlock Text="Card 2" /></Border>
            <Border Style="{StaticResource SystemCardStyle}" Grid.Row="0" Grid.Column="2"><TextBlock Text="Card 3" /></Border>
            <Border Style="{StaticResource SystemCardStyle}" Grid.Row="1" Grid.Column="0"><TextBlock Text="Card 4" /></Border>

            <Border Style="{StaticResource SystemCardStyle}" Grid.Row="1" Grid.Column="1"><TextBlock Text="Card 5" /></Border>
            <Border Style="{StaticResource SystemCardStyle}" Grid.Row="1" Grid.Column="2"><TextBlock Text="Card 6" /></Border>
            <Border Style="{StaticResource SystemCardStyle}" Grid.Row="2" Grid.Column="0"><TextBlock Text="Card 7" /></Border>

            <Border Style="{StaticResource SystemCardStyle}" Grid.Row="2" Grid.Column="1"><TextBlock Text="Card 8" /></Border>
            <Border Style="{StaticResource SystemCardStyle}" Grid.Row="2" Grid.Column="2"><TextBlock Text="Card 9" /></Border>
            <Border Style="{StaticResource SystemCardStyle}" Grid.Row="3" Grid.Column="0"><TextBlock Text="Card 10" /></Border>
            <Border Style="{StaticResource SystemCardStyle}" Grid.Row="3" Grid.Column="1"><TextBlock Text="Card 11" /></Border>
            <Border Style="{StaticResource SystemCardStyle}" Grid.Row="3" Grid.Column="2"><TextBlock Text="Card 12" /></Border>
        </Grid>
    </ScrollViewer>
</Page>
